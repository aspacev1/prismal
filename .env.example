# Copy to .env and fill in real values.

# Database connection.
#   - Production (docker-compose.yml): the app container reads this as-is, so
#     use the internal service hostname "postgres".
#   - Host-side dev/test (`npm run dev` / `npm test` run directly on your
#     machine): use "localhost". The dev compose file
#     (docker-compose.override.yml) overrides this to "postgres" for the
#     containerized dev server, so localhost here is correct for host-side runs.
DATABASE_URL="postgresql://flowline:flowline@postgres:5432/flowline"

AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true
POSTGRES_USER=flowline
POSTGRES_PASSWORD=flowline
POSTGRES_DB=flowline

# Public origin of the app, INCLUDING the scheme. It is compared against the
# browser Origin header for the CSRF same-origin check and used to build
# absolute invite links, so it must be the full public origin (not a bare
# host). Caddy also accepts a scheme-prefixed site address, so the same value
# works for the reverse proxy.
DOMAIN=https://example.com

RESEND_API_KEY="get-a-real-key-from-resend.com"
EMAIL_FROM="flowline <onboarding@resend.dev>"
