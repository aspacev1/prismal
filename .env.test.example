# Copy to .env.test for running the test suite (`npm test`).
# The test database runs on port 5433 (see docker-compose.test.yml) and is
# reached from the host, so use localhost.
DATABASE_URL="postgresql://flowline:flowline@localhost:5433/flowline_test"

AUTH_SECRET="test-secret-at-least-32-characters-long"
AUTH_TRUST_HOST=true

# Leave DOMAIN unset in tests so the origin check falls back to the request
# origin (http://localhost:3000), which the test requests use.

RESEND_API_KEY="re_test_placeholder"
EMAIL_FROM="flowline <test@resend.dev>"
